// GET: to Validate / Verify Employee by cognitoid
app.get('/api/verifyEmployee', async (req, res) => {
    const { id } = req.query;
    if (!id) {
        return res.status(400).json({ error: 'Bad Request', details: 'Missing id parameter' });
    }
    const query = 'SELECT empleado FROM usuario WHERE cognitoid = ?';

    try {
        const results = await executeQuery(query, [id]);
        if (results.length === 0) {
            return res.status(404).json({ error: 'User not found' });
        }
        const empleado = results[0].empleado;
        return res.json({ empleado });

    } catch (error) {
        console.error('Database error:', error);
        return res.status(500).json({ error: 'Database error', details: error.message });
    }
});

// GET: to Validate / Verify if a location exists
app.get('/api/verifyLocation', async (req, res) => {
    try {
        const { localizacion, idsucursal, num_parte } = req.query;

        // Validar que los parámetros necesarios estén presentes
        if (!localizacion || !idsucursal || !num_parte) {
            return res.status(400).json({ error: 'Bad Request', details: 'Missing parameters' });
        }

        const query = `
            SELECT d.num_parte
            FROM detalle d
            INNER JOIN localizacion l USING (idlocalizacion)
            INNER JOIN sucursal s USING (idsucursal)
            WHERE l.localizacion = ?
                AND s.idsucursal = ?
        `;

        const results = await executeQuery(query, [localizacion, idsucursal]);

        if (results.length === 0) {
            return res.json({ exists: false, message: 'Localización disponible.' });
        }

        const existingPart = results[0].num_parte;

        if (existingPart === num_parte) {
            return res.json({ exists: false, message: 'Localización ocupada por la misma refacción.' });
        } else {
            return res.json({ exists: true, message: 'Localización ocupada por otra refacción.' });
        }
    } catch (error) {
        console.error('Database error:', error);
        return res.status(500).json({ error: 'Database error', details: error.message });
    }
});

