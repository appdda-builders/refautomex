// POST: new sale
app.post('/api/newSale', async (req, res) => {
    const { fecha_venta, total_venta, idusuario, tipo, idmetodo, items, telefono, email, fecha_entrega, fecha_pedido, nombre_cliente, isOrder, notas } = req.body;

    if (!fecha_venta || !total_venta || !idusuario || !tipo || !idmetodo || !items || items.length === 0) {
        return res.status(400).json({
            error: 'Bad Request',
            details: 'Missing parameters or no items provided.'
        });
    }

    try {
        // Insertar la venta
        const query = 'CALL insertSale(?, ?, ?, "A", ?, ?, ?)';
        const params = [fecha_venta, total_venta, idusuario, idmetodo, tipo, notas];
        const results = await executeQuery(query, params);

        if (!results[0] || results[0].length === 0) {
            throw new Error('Failed to set idventa');
        }

        const { folio, idventa } = results[0][0];

        if (!idventa) {
            return res.status(500).json({
                error: 'IdVenta Error',
                details: 'No existing IdVenta after insertSale.'
            });
        }

        // Insertar detalle de venta
        for (let item of items) {
            if (!item.precio || !item.monto || !item.cantidad || !item.refaccion) {
                throw new Error(`Missing required item properties: ${JSON.stringify(item)}`);
            }

            const conceptQuery = `
                INSERT INTO concepto (precio_venta, monto_venta, cantidad, num_parte, type, pedido, concepto_comodin, idventa)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            `;
            const conceptParams = [
                parseFloat(item.precio).toFixed(2),
                parseFloat(item.monto).toFixed(2),
                item.cantidad,
                item.refaccion,
                item.isSeminew,
                item.isPedido ? 'P' : 'E',
                item.isEditable ? item.descripcion : null, // concepto_comodin
                idventa
            ];
            await executeQuery(conceptQuery, conceptParams);

            if (!item.isPedido) { //actualiza la existencia de la refaccion a nivel de detalle
                const updateStockQuery = `
                    UPDATE detalle
                    SET existencia = existencia - ?
                    WHERE num_parte = ?
                `;
                const updateStockParams = [
                    item.cantidad,
                    item.refaccion
                ];
                await executeQuery(updateStockQuery, updateStockParams);
            }
        }

        // Si es un pedido, insertamos información del cliente
        if (isOrder) {
            const insertOrderQuery = `
                INSERT INTO pedidos (idVenta, idusuario, f_pedido, f_entrega, nombre, telefono, status, email)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            `;
            const orderParams = [
                idventa,
                idusuario, // empleado
                fecha_pedido,
                fecha_entrega,
                nombre_cliente,
                telefono,
                'P',
                email
            ];
            await executeQuery(insertOrderQuery, orderParams);
        }

        // Devolver el folio generado como respuesta
        return res.json({ folio });
    } catch (err) {
        console.error('Error while processing sale:', err);
        return res.status(500).json({
            error: 'Internal Server Error',
            details: err.message
        });
    }
});


